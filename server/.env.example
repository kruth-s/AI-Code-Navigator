# Neon Database Connection
DATABASE_URL="postgresql://username:password@ep-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# GitHub OAuth (Create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_ID="your_github_oauth_client_id"
GITHUB_SECRET="your_github_oauth_client_secret"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# OpenAI / LLM Configuration
OPENAI_API_KEY="your_openai_api_key"

# Pinecone (if using cloud vector database)
PINECONE_API_KEY="your_pinecone_api_key"
PINECONE_INDEX_NAME="your_index_name"

# GitHub API Token (for accessing repositories)
GITHUB_TOKEN="your_github_personal_access_token"

# Groq (if using Groq for LLM)
GROQ_API_KEY="your_groq_api_key"

# Server Configuration
HOST=0.0.0.0
PORT=8000
